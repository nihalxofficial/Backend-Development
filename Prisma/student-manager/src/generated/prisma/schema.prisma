generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id    Int    @id @default(autoincrement())
  name  String
  email String @unique
}

model Student {
  id         Int      @id @default(autoincrement())
  name       String
  age        Int
  roll       Int      @unique
  department String
  admission  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
